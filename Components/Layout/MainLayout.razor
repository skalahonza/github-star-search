@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="app-shell">
    <header class="appbar">
        <div class="appbar-logo" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
            </svg>
        </div>
        <span class="appbar-title">Github Star Search</span>
        <div class="appbar-spacer"></div>
    </header>

    <main>
        @Body
    </main>
</div>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#7e6fff",
            Surface = "#16162a",
            Background = "#08080f",
            BackgroundGray = "#0c0c18",
            AppbarText = "#c8c6d8",
            AppbarBackground = "rgba(8,8,15,0.75)",
            DrawerBackground = "#08080f",
            ActionDefault = "#8886a0",
            TextPrimary = "#c8c6d8",
            TextSecondary = "#8886a0",
            Info = "#4a86ff",
            Success = "#3dcb6c",
            Warning = "#ffb545",
            Error = "#ff3f5f",
            LinesDefault = "rgba(126,111,255,0.15)",
            Divider = "rgba(126,111,255,0.12)",
        },
        LayoutProperties = new LayoutProperties()
    };
}
