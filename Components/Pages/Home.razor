@page "/"
@using Blazored.LocalStorage
@using GithubStarSearch.Searching
@using Markdig
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Octokit
@using Repository = GithubStarSearch.Searching.Repository

@inject ILogger<Home> Logger
@inject SearchService SearchService
@inject ILocalStorageService LocalStorage
@inject IConfiguration Configuration
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Github Star Search — Spacey</PageTitle>

<div class="container">
    <div class="grid-2">
        <!-- Username card -->
        <div class="card fade-up fade-up-1">
            <div class="card-label">
                <div class="card-icon card-icon-purple">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>
                </div>
                <span class="card-label-text">Enter your GitHub Username</span>
            </div>
            <div class="input-wrap" style="margin-bottom: 14px;">
                <span class="input-icon input-icon-left" style="color:#7e6fff;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10h5v-2h-5c-4.34 0-8-3.66-8-8s3.66-8 8-8 8 3.66 8 8v1.43c0 .79-.71 1.57-1.5 1.57s-1.5-.78-1.5-1.57V12c0-2.76-2.24-5-5-5s-5 2.24-5 5 2.24 5 5 5c1.38 0 2.64-.56 3.54-1.47.65.89 1.77 1.47 2.96 1.47 1.97 0 3.5-1.6 3.5-3.57V12c0-5.52-4.48-10-10-10zm0 13c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
                    </svg>
                </span>
                <input class="gss-input"
                       placeholder="Enter your GitHub username…"
                       maxlength="100"
                       @bind="GithubUsername"
                       @bind:event="oninput"
                       @onkeydown="OnUsernameKeyDown" />
            </div>
            <button @ref="_btnRef"
                    class="gss-btn"
                    type="button"
                    disabled="@(_isIndexing || string.IsNullOrWhiteSpace(GithubUsername))"
                    @onclick="SubmitUsername">
                @if (_isIndexing)
                {
                    <span class="spinner"></span>
                    <span>Probing the universe…</span>
                }
                else
                {
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M9.19 6.35c-2.04 2.29-3.44 5.58-3.57 5.89L2 10.69l4.5-4.5c.25-.25.64-.36 1.01-.27l1.68.43zm10.46 10.46l-1.61 1.61.43 1.68c.09.37-.02.76-.27 1.01L13.7 21.6l-1.55-3.62c.31-.13 3.58-1.53 5.88-3.57l1.62 1.4zm1.29-12.94C19.8 1.4 17.14.06 14.38.06c-3 0-5.9 1.23-7.98 3.38L4 5.85 5.17 9l-2.83 2.83c-.78.78-.78 2.05 0 2.83l7 7c.78.78 2.05.78 2.83 0L15 18.83l3.15 1.17 2.41-2.41c2.15-2.08 3.38-4.98 3.38-7.98 0-2.76-1.34-5.42-3.0-7.54zM14.5 11c-1.38 0-2.5-1.12-2.5-2.5S13.12 6 14.5 6 17 7.12 17 8.5 15.88 11 14.5 11z"/>
                    </svg>
                    <span>Send Probe to Index Stars 🌟</span>
                }
            </button>
            <p class="caption">
                You only have to do this once. Username is saved as a query parameter so you can bookmark the page and share it with others.
            </p>
        </div>

        <!-- Search card -->
        <div class="card fade-up fade-up-2">
            <div class="card-label">
                <div class="card-icon card-icon-blue">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    </svg>
                </div>
                <span class="card-label-text">Search Starred Repositories</span>
            </div>
            <div class="input-wrap">
                <span class="input-icon input-icon-left" style="color:@(IsIndexed ? "#4a86ff" : "#42405a");">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    </svg>
                </span>
                <input @ref="_searchRef"
                       class="gss-input has-right"
                       placeholder="@(IsIndexed ? "Search starred repositories…" : "Index your stars first…")"
                       disabled="@(string.IsNullOrEmpty(GithubUsername))"
                       maxlength="1000"
                       @bind="_searchQueryInput"
                       @bind:event="oninput"
                       @bind:after="OnSearchInput"
                       @onkeydown="OnSearchKeyDown" />
                <span class="input-icon input-icon-right" style="color:@(IsIndexed ? "#4a86ff" : "#32303e");">
                    @if (IsIndexed)
                    {
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M21.9 8.89l-1.05-4.37c-.22-.9-1-1.52-1.91-1.52H5.07c-.91 0-1.69.62-1.91 1.52L2.1 8.89c-.24 1.02-.02 2.06.62 2.88.08.11.19.19.28.29V19c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-6.94c.09-.09.2-.18.28-.28.64-.82.87-1.87.62-2.89z"/>
                        </svg>
                    }
                    else
                    {
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                        </svg>
                    }
                </span>
            </div>
            <p class="caption">
                Results appear instantly as you type. Use the minus (-) operator in front of a word to exclude it from results.
            </p>
        </div>
    </div>

    @if (_searchResults.Count > 0)
    {
        <div class="results-header fade-up">
            <span class="results-count">@_searchResults.Count result@(_searchResults.Count != 1 ? "s" : "")</span>
            <span class="results-label">matching "<strong>@_searchQuery</strong>"</span>
        </div>

        @for (var i = 0; i < _searchResults.Count; i++)
        {
            var repo = _searchResults[i];
            var delay = $"{i * 0.07:0.00}s";
            <div class="repo-card" style="animation-delay: @delay;">
                <div class="repo-streak"></div>
                <div class="repo-header">
                    <div class="repo-title">
                        <span class="repo-owner">@repo.Owner/</span><span class="repo-slug">@((MarkupString)repo.Slug)</span>
                    </div>
                    <a class="view-repo-btn view-repo-btn-icon" href="@repo.Url" target="_blank" rel="noreferrer" title="View on GitHub">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/>
                        </svg>
                    </a>
                </div>
                <p class="repo-desc">@((MarkupString)(repo.Description ?? ""))</p>
                <hr class="divider" style="margin:12px 0;" />
                <div class="repo-readme">
                    @((MarkupString)Markdown.ToHtml(repo.Readme ?? ""))
                </div>
                <div class="repo-footer">
                    <span class="repo-updated">Updated @repo.UpdatedAt.ToLocalTime().ToString("MM/dd/yyyy HH:mm")</span>
                    <a class="view-repo-btn" href="@repo.Url" target="_blank" rel="noreferrer">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>
                        </svg>
                        <span>View Repository</span>
                    </a>
                </div>
            </div>
        }
    }
    else
    {
        @if (string.IsNullOrEmpty(GithubUsername))
        {
            <section class="welcome fade-up fade-up-3">
                <div class="welcome-glow"></div>
                <span class="welcome-planet">🌌</span>
                <h2 class="welcome-title">Welcome to GitHub Star Search</h2>
                <hr class="divider" />
                <p class="welcome-body">
                    Did you star over 500 repositories and now can't find that awesome library you bookmarked last week?
                    <strong>GitHub Star Search</strong> is here to save the day — blazing-fast full-text search across all your starred repos.
                </p>
            </section>
        }

        <section class="howto fade-up fade-up-3">
            <h2 class="howto-title">How to Use</h2>
            <hr class="divider" />
            <div class="howto-steps">
                <div class="step">
                    <div class="step-icon" style="background: rgba(126,111,255,0.12);">🚀</div>
                    <div class="step-title">1. Enter username</div>
                    <div class="step-desc">Type your GitHub handle and fire the probe. You only have to do this once — we remember it.</div>
                </div>
                <div class="step">
                    <div class="step-icon" style="background: rgba(74,134,255,0.12);">🔭</div>
                    <div class="step-title">2. Search instantly</div>
                    <div class="step-desc">Results appear as you type, debounced so every keystroke counts.</div>
                </div>
                <div class="step">
                    <div class="step-icon" style="background: rgba(61,203,108,0.12);">✨</div>
                    <div class="step-title">3. Find anything</div>
                    <div class="step-desc">Full-text across names, descriptions and READMEs. Use - to exclude words.</div>
                </div>
            </div>
            <hr class="divider" style="margin-top:28px;" />
            <p class="caption">Note: We only index public starred repositories. Some users may not have public star data available.</p>
        </section>
    }

    <footer class="footer fade-up fade-up-4">
        <div>Built with ❤️ by <a href="https://github.com/skalahonza" target="_blank" rel="noreferrer">skalahonza</a></div>
        <div style="margin-top:6px;">
            Powered by <a href="https://www.meilisearch.com/" target="_blank" rel="noreferrer">MeiliSearch</a>
        </div>
    </footer>
</div>

@code {

    [SupplyParameterFromQuery(Name = "username")]
    public string GithubUsername { get; set; } = "";

    private bool _isIndexing;
    private bool _isIndexed;
    private bool IsIndexed => _isIndexed && !string.IsNullOrEmpty(GithubUsername);

    private readonly List<Repository> _searchResults = new();
    private string _searchQuery = "";
    private string _searchQueryInput = "";

    private CancellationTokenSource? _debounceCts;
    private ElementReference _btnRef;
    private ElementReference _searchRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadState();
            if (!string.IsNullOrEmpty(GithubUsername))
            {
                _isIndexed = true;
            }
            StateHasChanged();
        }
    }

    private async Task OnUsernameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitUsername();
        }
    }

    private async Task SubmitUsername()
    {
        if (string.IsNullOrWhiteSpace(GithubUsername) || GithubUsername.Length > 100)
        {
            return;
        }

        await SaveState();

#if RELEASE
        if (await SearchService.IsIndexed(GithubUsername))
        {
            Logger.LogInformation("Repositories already indexed for {Username}", GithubUsername);
            Snackbar.Add("Repositories already indexed", Severity.Info);
            _isIndexed = true;
            await BurstAtSearch("#4a86ff", 24);
            return;
        }
#endif

        _isIndexing = true;
        StateHasChanged();

        // Warp burst around the button
        try { await JS.InvokeVoidAsync("ParticleBurst.warpBurst", 50); } catch { /* JS may not be ready */ }

        try
        {
            Logger.LogInformation("Indexing user repos for {Username}", GithubUsername);
            var token = Configuration["Github:FineGrainedToken"];
            var github = new GitHubClient(new ProductHeaderValue("GithubStarSearch"));
            if (string.IsNullOrEmpty(token))
            {
                Logger.LogWarning("No fine grained token found, using anonymous client. This might lead to rate limiting");
            }
            else
            {
                Logger.LogInformation("Using fine grained token for authenticated requests");
                github.Credentials = new Credentials(token);
            }

            Logger.LogInformation("Fetching user {Username} starred repositories", GithubUsername);
            var starred = await github.Activity.Starring.GetAllForUser(GithubUsername);

            if (starred.Count > 5000)
            {
                Logger.LogWarning("User {Username} has starred more than 5000 repositories, only the first 5000 will be indexed", GithubUsername);
                Snackbar.Add("User has starred more than 5000 repositories, only the first 5000 will be indexed", Severity.Warning);
                starred = starred.Take(5000).ToList();
            }

            Logger.LogInformation("Indexing {Count} repositories starred by {Username}", starred.Count, GithubUsername);
            await SearchService.IndexRepositories(starred
                .Where(x => !x.Private)
                .Select(x => Repository.FromGithubRepository(x, GithubUsername)));
            Logger.LogInformation("User {Username} onboarded successfully", GithubUsername);
            Snackbar.Add("Stars indexed — ready to explore! 🚀", Severity.Success);
            _isIndexed = true;
            await BurstAtSearch("#4a86ff", 24);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error while indexing starred repositories", Severity.Error);
            Logger.LogError(ex, "Error while indexing user {Username} starred repositories", GithubUsername);
        }
        finally
        {
            _isIndexing = false;
        }
    }

    private async Task BurstAtSearch(string color, int count)
    {
        try
        {
            await JS.InvokeVoidAsync("ParticleBurst.burstAt", _searchRef, color, count);
        }
        catch { /* ignore */ }
    }

    private async Task OnSearchInput()
    {
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;
        try
        {
            await Task.Delay(300, token);
            if (!token.IsCancellationRequested)
            {
                await Search(_searchQueryInput);
            }
        }
        catch (TaskCanceledException) { /* expected */ }
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && _searchResults.Count > 0)
        {
            try { await JS.InvokeVoidAsync("ParticleBurst.burstAt", _searchRef, "#7e6fff", 18); } catch { }
        }
    }

    private async Task Search(string searchQuery)
    {
        _searchQuery = searchQuery ?? "";
        _searchResults.Clear();

        if (string.IsNullOrWhiteSpace(_searchQuery) || _searchQuery.Length > 1000)
        {
            StateHasChanged();
            return;
        }

        var results = await SearchService.SearchRepositories(GithubUsername, _searchQuery, new SearchOptions
        {
            HighlightPreTag = "<mark class=\"gss-mark\">",
            HighlightPostTag = "</mark>",
        });
        _searchResults.AddRange(results);

        if (_searchResults.Count == 0)
        {
            Snackbar.Add("No stars found for that query", Severity.Warning);
        }

        StateHasChanged();
    }

    private async Task SaveState()
    {
        Navigation.NavigateTo(Navigation.GetUriWithQueryParameter("username", GithubUsername));
        await LocalStorage.SetItemAsync("GithubUsername", GithubUsername);
    }

    private async Task LoadState()
    {
        if (string.IsNullOrEmpty(GithubUsername))
        {
            GithubUsername = await LocalStorage.GetItemAsync<string>("GithubUsername") ?? "";
            Logger.LogInformation("Github username loaded from local storage: {Username}", GithubUsername);
        }
    }
}
